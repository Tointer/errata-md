{
  "name": "errata",
  "version": "1.7.0",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite dev --port 7739",
    "dev:web": "vite dev --host 127.0.0.1 --port 3000",
    "dev:web:electron": "vite dev --host 127.0.0.1 --port 3000 --strictPort",
    "dev:backend": "tsx src/server/standalone.ts",
    "dev:share": "node scripts/proxy-with-qr.mjs",
    "electron:dev": "npm run electron:dev:reset && concurrently -k -s first -n web,electron \"cross-env ERRATA_DISABLE_DEVTOOLS=1 VITE_ERRATA_API_BASE=http://127.0.0.1:7739/api npm run dev:web:electron\" \"npm run electron:dev:main\"",
    "electron:dev:main": "wait-on http://127.0.0.1:3000 && cross-env ELECTRON_RENDERER_PORT=3000 node scripts/electron-dev.mjs",
    "electron:dev:reset": "kill-port 3000 7739",
    "electron:start": "electron electron/main.mjs",
    "desktop:build": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder",
    "build": "vite build",
    "new:plugin": "node scripts/new-plugin.mjs",
    "build:binary": "node -e \"throw new Error('Standalone binary builds are disabled during the Node migration.')\"",
    "package:binary": "node -e \"throw new Error('Standalone binary builds are disabled during the Node migration.')\"",
    "release:binary": "node -e \"throw new Error('Standalone binary builds are disabled during the Node migration.')\"",
    "stress:backend": "tsx scripts/backend-stress-harness.ts",
    "docs:sync": "tsx scripts/sync-docs-from-commits.ts",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@ai-sdk/react": "^3.0.88",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/openapi": "^1.4.14",
    "@floating-ui/react": "^0.27.18",
    "@sinclair/typebox": "^0.34.48",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/react-virtual": "^3.13.19",
    "@tanstack/router-plugin": "^1.132.0",
    "@tealios/errata-plugin-sdk": "file:packages/errata-plugin-sdk",
    "@tiptap/extension-bubble-menu": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@uiw/react-codemirror": "^4.25.9",
    "ai": "^6.0.86",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elysia": "^1.4.25",
    "fflate": "^0.8.2",
    "lucide-react": "^0.564.0",
    "nitro": "npm:nitro-nightly@latest",
    "openapi-types": "^12.1.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^27.0.0",
    "kill-port": "^2.0.1",
    "qrcode-terminal": "^0.12.0",
    "shadcn": "^3.8.4",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.0.5",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.errata.desktop",
    "productName": "Errata",
    "directories": {
      "output": "release"
    },
    "files": [
      ".output/**/*",
      "electron/**/*",
      "plugins/**/*",
      "packages/errata-plugin-sdk/**/*",
      "public/**/*",
      "package.json"
    ],
    "asar": true,
    "extraMetadata": {
      "main": "electron/main.mjs"
    },
    "win": {
      "icon": "public/favicon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "optionalDependencies": {
    "lightningcss-linux-x64-gnu": "^1.31.1",
    "lightningcss-win32-x64-msvc": "^1.31.1"
  }
}
